# Server
PORT=3000
NODE_ENV=dev            # "dev" -> verbose errors, "prod" -> safe errors + secure cookies

# Database
MONGO_URI=mongodb://127.0.0.1:27017/casaclean

# Auth / JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES=7         # cookie lifetime in days

# URLs
CLIENT_URL=http://localhost:5173     # frontend, used for post-verification redirects
SERVER_URL=http://localhost:3000     # this API's public base URL, used to build verification links

# Email (Mailtrap sandbox in dev — grab these from your Mailtrap inbox's SMTP settings)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_FROM="CasaClean <noreply@casaclean.com>"

# Google OAuth information
GOOGLE_CLIENT_ID=your-google-id
GOOGLE_CLIENT_SECRET=your-google-secret
GOOGLE_CALLBACK_URL=google-callback-url

SENTRY_DSN=test
