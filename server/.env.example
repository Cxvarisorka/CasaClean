# Server
PORT=3000
# "development" -> verbose errors, relaxed cookies (local HTTP).
# ANY other value (including the conventional "production") -> safe errors +
# Secure/SameSite=None cookies. Security behaviour fails secure; see utils/env.util.js.
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/casaclean

# Auth / JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES=7         # cookie lifetime in days

# URLs
CLIENT_URL=http://localhost:5173     # frontend, used for post-verification redirects
SERVER_URL=http://localhost:3000     # this API's public base URL, used to build verification links

# Email (Mailtrap sandbox in dev — grab these from your Mailtrap inbox's SMTP settings)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_FROM="CasaClean <noreply@casaclean.com>"

# Google OAuth information
GOOGLE_CLIENT_ID=your-google-id
GOOGLE_CLIENT_SECRET=your-google-secret
GOOGLE_CALLBACK_URL=google-callback-url

# Stripe payments
# STRIPE_SECRET_KEY  — server-side API key (test: sk_test_... / live: sk_live_...)
# STRIPE_WEBHOOK_SECRET — signing secret for /webhooks/stripe (whsec_...).
#   In dev, `stripe listen --forward-to localhost:3000/webhooks/stripe` prints it.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

SENTRY_DSN=test
