    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking (logged-in user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/booking", "host": ["{{baseUrl}}"], "path": ["booking"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": 1,\n  \"cityId\": 1,\n  \"streetName\": \"Rustaveli Ave\",\n  \"houseNumber\": \"12\",\n  \"propertySize\": \"80m2\",\n  \"doorbellName\": \"Smith\",\n  \"bookingDate\": \"2026-07-01\",\n  \"bookingTime\": \"14:00\",\n  \"hours\": 3,\n  \"cleaners\": 2,\n  \"totalAmount\": 120,\n  \"notes\": \"Please bring eco products\",\n  \"supplies\": [\"vacuum\", \"mop\"]\n}"
            },
            "description": "Any logged-in user. Create a booking. Contact name/email come from your account (not the body). serviceId/cityId are NUMBERS. Status defaults to 'confirmed'. Expect 201. The new id is saved to bookingId.\n\nTo test add-ons, add a valid enabled id to specialRequests, e.g.: \"specialRequests\": [\"{{specialRequestId}}\"] (create one in the Special Request group first)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.code === 201);",
                  "const b = pm.response.json().data.booking;",
                  "if (b && b._id) { pm.collectionVariables.set('bookingId', b._id); }",
                  "pm.test('Status defaults to confirmed', () => pm.expect(b.status).to.eql('confirmed'));",
                  "pm.test('Contact email comes from account', () => pm.expect(b.customerEmail).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Bookings (logged-in user)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/booking/my?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "my"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Any logged-in user. List ONLY your own bookings, newest first. Expect 200 with data.bookings (a list) and bookingCount. Without a cookie = 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.code === 200);",
                  "pm.test('bookings is a list', () => pm.expect(pm.response.json().data.bookings).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Bookings (admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/booking?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["booking"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Admin only. List ALL bookings (everyone's), newest first. Expect 200 with data.bookings and bookingCount. A normal user = 403, no cookie = 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.code === 200);",
                  "pm.test('bookings is a list', () => pm.expect(pm.response.json().data.bookings).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Booking by id (admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/booking/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["booking", "{{bookingId}}"] },
            "description": "Admin only. Get one booking. Uses the bookingId variable (set by Create Booking). Expect 200. Unknown id = 404, broken id = 400, normal user = 403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 200 OK', () => pm.response.code === 200);"]
              }
            }
          ]
        },
        {
          "name": "Edit Booking (admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
