            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\",\n  \"totalAmount\": 130\n}"
            },
            "description": "Admin only. Change only allowed fields (status, dates, hours, cleaners, totalAmount, address, notes, supplies, specialRequests). status must be one of pending/confirmed/cancelled/completed. Fields like user/customerEmail are ignored. Expect 200."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.code === 200);",
                  "pm.test('status is now completed', () => pm.expect(pm.response.json().data.booking.status).to.eql('completed'));"
                ]
              }
            }
          ]
        },
