                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.code === 200);",
                  "pm.test('enabled is now false', () => pm.expect(pm.response.json().data.service.enabled).to.eql(false));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Service (admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/service/{{serviceId}}", "host": ["{{baseUrl}}"], "path": ["service", "{{serviceId}}"] },
            "description": "Admin only. Delete a service. Expect 200. Deleting again = 404."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 200 OK', () => pm.response.code === 200);"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Special Request",
      "item": [
        {
          "name": "Get Special Requests (list)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/special-request?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["special-request"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Public. List the booking add-ons with paging, newest first. Expect 200 with data.specialRequests (a list) and specialRequestCount."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.code === 200);",
                  "pm.test('specialRequests is a list', () => pm.expect(pm.response.json().data.specialRequests).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Special Request (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/special-request", "host": ["{{baseUrl}}"], "path": ["special-request"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fridge cleaning\",\n  \"description\": \"Clean the inside of the fridge\",\n  \"price\": 15\n}"
            },
            "description": "Admin only. Create an add-on. Expect 201. Name capital letter is fixed automatically. Enabled is true by default. The new id is saved to specialRequestId for the other requests (and the Booking requests)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.code === 201);",
                  "const sr = pm.response.json().data.specialRequest;",
                  "if (sr && sr._id) { pm.collectionVariables.set('specialRequestId', sr._id); }",
                  "pm.test('Name was capitalized', () => pm.expect(sr.name).to.eql('Fridge cleaning'));",
                  "pm.test('Enabled by default', () => pm.expect(sr.enabled).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Special Request by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/special-request/{{specialRequestId}}", "host": ["{{baseUrl}}"], "path": ["special-request", "{{specialRequestId}}"] },
            "description": "Public. Get one add-on. Uses the specialRequestId variable (set by Add Special Request). Expect 200. Unknown id = 404, broken id = 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 200 OK', () => pm.response.code === 200);"]
