                  "if (s && s._id) { pm.collectionVariables.set('serviceId', s._id); }",
                  "pm.test('allCities is true', () => pm.expect(s.allCities).to.eql(true));",
                  "pm.test('cities list is empty', () => pm.expect(s.cities).to.be.an('array').that.is.empty);"
                ]
              }
            }
          ]
        },
        {
