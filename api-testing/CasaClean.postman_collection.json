                  "pm.test('services is a list', () => pm.expect(pm.response.json().data.services).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Service - all cities (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/service", "host": ["{{baseUrl}}"], "path": ["service"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Deep cleaning\",\n  \"description\": \"Full deep clean\",\n  \"pricePerHour\": 30,\n  \"allCities\": true\n}"
            },
            "description": "Admin only. Create a service offered EVERYWHERE. Expect 201, allCities true, cities empty. The new id is saved to serviceId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.code === 201);",
