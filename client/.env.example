# CasaClean — frontend environment
# Base URL of the CasaClean API (no trailing slash).
VITE_API_BASE_URL=

# Public site origin, used for canonical URLs and SEO metadata.
VITE_SITE_URL=

# Google Maps JavaScript API key — powers the admin "Coverage map" section.
# Create one at https://console.cloud.google.com/ and enable "Maps JavaScript API".
# Without it the map shows a setup notice; the city breakdown still works.
VITE_GOOGLE_MAPS_API_KEY=

# Stripe publishable key (pk_test_... / pk_live_...) — powers card checkout and
# saved-card management. Pair it with the server's STRIPE_SECRET_KEY (same mode).
# Without it the booking flow shows a "payments unavailable" notice.
VITE_STRIPE_PUBLISHABLE_KEY=
